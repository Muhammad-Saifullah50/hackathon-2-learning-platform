# Kong Database Configuration
KONG_PG_PASSWORD=your-secure-password-here

# Redis Configuration
REDIS_PASSWORD=your-redis-password-here

# JWT Configuration (paths to key files)
JWT_PRIVATE_KEY_PATH=backend/auth-service/keys/jwt_key
JWT_PUBLIC_KEY_PATH=backend/auth-service/keys/jwt_key.pub

# Neon Database (from NEON_DATABASE.md)
NEON_DATABASE_URL=postgresql://user:password@host/database

# API Keys (if needed)
# OPENAI_API_KEY=your-api-key-here
# ANTHROPIC_API_KEY=your-api-key-here
